<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stardeck_bg_bottom">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/bottomNavDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/stardeck_bottom_nav_stroke"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav_bar"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:minHeight="72dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            app:itemActiveIndicatorStyle="@null"
            app:itemBackground="@android:color/transparent"
            app:itemHorizontalTranslationEnabled="false"
            app:itemIconSize="22dp"
            app:itemIconTint="@color/selector_bottom_nav_icon"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextColor="@color/selector_bottom_nav_text"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_admin_bottom_nav" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>