<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/stardeck_field_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Rank badge -->
        <TextView
            android:id="@+id/tvRank"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/stardeck_text_primary" />

        <!-- Avatar circle with initial -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="A"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/stardeck_text_primary"
            android:background="@drawable/bg_avatar_circle" />

        <!-- Name + rank label + stats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/stardeck_text_primary" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Rank #1"
                android:textSize="11sp"
                android:textColor="@color/stardeck_primary" />

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Total: 120 • Streak: 5 days"
                android:textSize="12sp"
                android:textColor="@color/stardeck_text_secondary" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
