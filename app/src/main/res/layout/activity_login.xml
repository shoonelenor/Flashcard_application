<?xml version="1.0" encoding="utf-8"?>
<!--
    LOGIN SCREEN  — StarDeck redesign
    ─────────────────────────────────
    Structure:
      • Full-screen space background (bg_login_space)
      • NestedScrollView fills the screen
      • Inner LinearLayout: logo header  +  frosted card form panel
        +  spacer  +  footer links
      • Card panel (bg_login_card): email field, password field,
        forgot-password link, login button, sign-up row,
        social-auth divider, social buttons

    Design decisions:
      • Labels LEFT-aligned (not centred) for better readability
      • Input corner radius 14dp; card corner radius 24dp;
        login button 28dp (pill) — nested radius correctly reduced
      • Button height 56dp, text 16sp = accessible tap target
      • Social icon buttons 52dp circles = ≥44dp touch target
      • Spacing uses multiples of 4dp (8, 12, 16, 20, 24)
      • All hard-coded colours reference @color/* tokens
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_space">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="24dp">

            <!-- ── Logo + Brand ────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logoCard"
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stardeck_divider"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_logo_tile">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_app_logo"
                        android:src="@drawable/ic_stardeck_star" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.04"
                android:text="@string/login_brand_name"
                android:textColor="@color/stardeck_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/login_tagline"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="14sp" />

            <!-- ── Form Card ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_login_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Email label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/email_address"
                    android:textColor="@color/stardeck_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

                <!-- Email input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.StarDeck.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="emailAddress"
                        android:hint="@string/email_address_hint"
                        android:imeOptions="actionNext"
                        android:inputType="textEmailAddress"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:textColor="@color/stardeck_text_primary"
                        android:textColorHint="@color/stardeck_text_hint"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/password"
                    android:textColor="@color/stardeck_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

                <!-- Password input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.StarDeck.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:endIconContentDescription="@string/cd_toggle_password_visibility"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="password"
                        android:hint="@string/password_hint"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:textColor="@color/stardeck_text_primary"
                        android:textColorHint="@color/stardeck_text_hint"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Forgot password (end-aligned) -->
                <TextView
                    android:id="@+id/btnForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:padding="6dp"
                    android:text="@string/forgot_password"
                    android:textColor="@color/stardeck_link"
                    android:textSize="13sp" />

                <!-- Login button + progress indicator -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        style="@style/Widget.StarDeck.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/log_in" />

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressLogin"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="18dp"
                        android:visibility="gone"
                        app:indicatorColor="@color/white"
                        app:indicatorSize="22dp"
                        app:trackColor="@color/stardeck_overlay_medium"
                        app:trackThickness="3dp" />
                </FrameLayout>

                <!-- Sign-up row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/new_explorer"
                        android:textColor="@color/stardeck_text_secondary"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoRegister"
                        style="@style/Widget.StarDeck.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_account"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Divider with label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/stardeck_divider" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/sign_in_with"
                        android:textColor="@color/stardeck_text_secondary"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/stardeck_divider" />
                </LinearLayout>

                <!-- Social auth buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Google -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnGoogle"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:clickable="true"
                        android:contentDescription="@string/google_sign_in"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:cardBackgroundColor="@color/stardeck_field_bg"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/stardeck_divider"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/google_sign_in"
                            android:src="@drawable/ic_google" />
                    </com.google.android.material.card.MaterialCardView>

                    <Space
                        android:layout_width="16dp"
                        android:layout_height="1dp" />

                    <!-- Facebook -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnFacebook"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:clickable="true"
                        android:contentDescription="@string/facebook_sign_in"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:cardBackgroundColor="@color/stardeck_field_bg"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/stardeck_divider"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/facebook_sign_in"
                            android:src="@drawable/ic_facebook" />
                    </com.google.android.material.card.MaterialCardView>

                    <Space
                        android:layout_width="16dp"
                        android:layout_height="1dp" />

                    <!-- X / Twitter -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnX"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:clickable="true"
                        android:contentDescription="@string/x_sign_in"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:cardBackgroundColor="@color/stardeck_field_bg"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/stardeck_divider"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/x_sign_in"
                            android:src="@drawable/ic_x" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
            <!-- end Form Card -->

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ── Footer ──────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/footerLinks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="@string/terms"
                    android:textColor="@color/stardeck_link"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text="·"
                    android:textColor="@color/stardeck_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btnPrivacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="@string/privacy"
                    android:textColor="@color/stardeck_link"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCopyright"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingBottom="4dp"
                android:text="@string/copyright_text"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
