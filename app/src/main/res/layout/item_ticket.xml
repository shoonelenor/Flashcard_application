<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/stardeck_field_bg"
    app:strokeColor="@color/stardeck_field_stroke"
    app:strokeWidth="1dp"
    app:rippleColor="?attr/colorControlHighlight">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Ticket ID + Status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTicketId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/stardeck_text_secondary"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvTicketStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <!-- Row 2: Reason -->
        <TextView
            android:id="@+id/tvTicketReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/stardeck_text_primary"
            android:layout_marginBottom="4dp" />

        <!-- Row 3: Reporter -->
        <TextView
            android:id="@+id/tvTicketReporter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/stardeck_text_secondary"
            android:layout_marginBottom="8dp" />

        <!-- Row 4: Details (clipped) -->
        <TextView
            android:id="@+id/tvTicketDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:textColor="@color/stardeck_text_primary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/stardeck_field_stroke"
            android:layout_marginBottom="10dp" />

        <!-- Row 5: Date + Action button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTicketDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="@color/stardeck_text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTicketAction"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
