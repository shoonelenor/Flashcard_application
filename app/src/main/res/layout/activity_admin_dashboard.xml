<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.admin.AdminDashboardActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:layout_scrollFlags="scroll|enterAlways" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gap="16dp">

            <!-- ── Section: Overview KPIs ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overview"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:rowCount="5"
                app:useDefaultMargins="true">

                <!-- Users -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Users" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvTotalUsers" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" tools:text="124" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Premium Users -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Premium" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvPremiumUsers" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" android:textColor="#d19900" tools:text="32" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Disabled Users -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Disabled" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvDisabledUsers" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" android:textColor="#a12c7b" tools:text="3" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Total Decks -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Decks" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvTotalDecks" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" tools:text="88" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hidden Decks -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hidden Decks" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvHiddenDecks" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" android:textColor="#a13544" tools:text="5" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Total Cards -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Cards" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvTotalCards" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" tools:text="1204" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Study Sessions -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Study Sessions" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvStudySessions" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" tools:text="340" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Open Reports -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Open Reports" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvOpenReports" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" android:textColor="#a13544" tools:text="2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Active This Month -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Active (month)" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvActiveThisMonth" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" android:textColor="#437a22" tools:text="91" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Inactive This Month -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Inactive (month)" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvInactiveThisMonth" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" android:textColor="#da7101" tools:text="33" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Achievements Unlocked -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Achievements" android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:alpha="0.7" />
                        <TextView android:id="@+id/tvAchievementsUnlocked" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textStyle="bold" tools:text="56" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.gridlayout.widget.GridLayout>

            <!-- ── Section: Pie Charts ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breakdowns"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <!-- User status pie -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="User Status" android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieUsers"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Deck visibility pie -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Deck Visibility" android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieDecks"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Monthly activity pie -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Monthly Activity" android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieActivity"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Section: Bar Charts ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top Content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <!-- Top categories bar -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Top Categories" android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barCategories"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Top languages bar -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Top Languages" android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barLanguages"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Top subjects bar -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Top Subjects" android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barSubjects"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
