<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/stardeck_dialog_bg"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <!-- ── Trophy icon + Title row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tvDialogTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Session Complete"
                android:textColor="@color/stardeck_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Mode badge ── -->
        <TextView
            android:id="@+id/tvDialogMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_badge_mode"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Normal Review"
            android:textColor="@color/stardeck_primary_light"
            android:textSize="12sp" />

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="16dp"
            android:background="@color/stardeck_dialog_stroke" />

        <!-- ── Cards Studied row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cards Studied"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDialogStudied"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 0"
                android:textColor="@color/stardeck_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Known row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Known"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDialogKnown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 (0%)"
                android:textColor="@color/stardeck_success"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Hard row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Hard"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDialogHard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 (0%)"
                android:textColor="@color/stardeck_error"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="14dp"
            android:background="@color/stardeck_dialog_stroke" />

        <!-- ── Accuracy block ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accuracy"
                    android:textColor="@color/stardeck_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDialogAccuracy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="100%"
                    android:textColor="@color/stardeck_primary_light"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Emoji result badge -->
            <TextView
                android:id="@+id/tvDialogEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_result"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="🌟 Excellent!"
                android:textColor="@color/stardeck_gold_text"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Achievement unlocked (hidden by default) ── -->
        <LinearLayout
            android:id="@+id/rowAchievement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_achievement_row"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏅"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDialogAchievement"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="1 achievement unlocked!"
                android:textColor="@color/stardeck_gold_text"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Action Buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogDone"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="80dp"
                android:text="Done"
                android:textAllCaps="false"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogRestart"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:minWidth="96dp"
                android:text="Restart"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/stardeck_primary"
                app:cornerRadius="22dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
