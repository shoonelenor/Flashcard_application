<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/stardeck_bg_top">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/stardeck_bg_top"
        android:title="Friends"
        android:titleTextColor="@color/stardeck_text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Tab Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:background="@color/stardeck_field_bg"
            android:padding="4dp">

            <Button
                android:id="@+id/btnTabFriends"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:text="My Friends"
                android:textSize="12sp"
                android:textColor="@color/stardeck_text_primary"
                android:backgroundTint="@color/stardeck_primary" />

            <Button
                android:id="@+id/btnTabRequests"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="Requests"
                android:textSize="12sp"
                android:textColor="@color/stardeck_text_secondary" />

            <Button
                android:id="@+id/btnTabFind"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:text="Find Users"
                android:textSize="12sp"
                android:textColor="@color/stardeck_text_secondary" />

        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                android:hint="Search by name or email">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFriendSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    android:textColor="@color/stardeck_text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnFriendSearch"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:backgroundTint="@color/stardeck_primary"
                android:textColor="@color/white" />

        </LinearLayout>

        <!-- Count label -->
        <TextView
            android:id="@+id/tvFriendCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Friends: 0"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/stardeck_text_secondary" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="48dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvFriendEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No friends yet"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/stardeck_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Use Find Users to add friends"
                android:textSize="13sp"
                android:textColor="@color/stardeck_text_hint"
                android:gravity="center" />

        </LinearLayout>

        <ListView
            android:id="@+id/listFriends"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@color/stardeck_field_stroke"
            android:dividerHeight="1dp" />

    </LinearLayout>

</LinearLayout>
