<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stardeck_bg_bottom">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/stardeck_bg_bottom"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/stardeck_bg_bottom"
            app:navigationIconTint="@color/stardeck_text_primary"
            app:titleTextColor="@color/stardeck_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main scroll content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Progress -->
            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1 / 10"
                android:textColor="@color/stardeck_text_secondary"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:indicatorColor="@color/stardeck_primary"
                app:trackColor="@color/stardeck_bg_surface"
                app:trackCornerRadius="4dp" />

            <!-- Question card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/stardeck_bg_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/tvQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Question text goes here"
                    android:textColor="@color/stardeck_text_primary"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Feedback -->
            <TextView
                android:id="@+id/tvFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:visibility="gone" />

            <!-- Option buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:minHeight="56dp"
                android:text="Option 1"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/stardeck_primary"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="56dp"
                android:text="Option 2"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/stardeck_primary"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="56dp"
                android:text="Option 3"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/stardeck_primary"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="56dp"
                android:text="Option 4"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/stardeck_primary"
                app:cornerRadius="12dp" />

            <!-- Next button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:text="Next →"
                android:textAllCaps="false"
                android:visibility="gone"
                app:backgroundTint="@color/stardeck_primary"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
