<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/stardeck_bg_bottom">

    <!-- ── HEADER BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="18dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="11dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A66BB6A">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sd_ticket"
                android:contentDescription="Tickets" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUPPORT"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvTicketOpenCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading…"
                android:textColor="@color/stardeck_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Admin badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_home_circle_chip"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="ADMIN"
            android:textColor="@color/stardeck_link"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

    </LinearLayout>

    <!-- ── FILTER CHIPS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="All"
            android:textSize="12sp"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterOpen"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Open"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterResolved"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Resolved"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ── DIVIDER ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/stardeck_field_stroke"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="4dp" />

    <!-- ── LOADING ── -->
    <ProgressBar
        android:id="@+id/progressTickets"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- ── EMPTY STATE ── -->
    <LinearLayout
        android:id="@+id/layoutTicketsEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_home_circle_chip"
            android:gravity="center"
            android:text="🎫"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No tickets yet"
            android:textColor="@color/stardeck_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTicketsEmptyLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="All support tickets will appear here"
            android:textColor="@color/stardeck_text_secondary"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ── TICKET LIST (ListView kept for existing ArrayAdapter) ── -->
    <ListView
        android:id="@+id/listViewTickets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="8dp"
        android:paddingBottom="110dp"
        android:clipToPadding="false"
        android:divider="@color/stardeck_field_stroke"
        android:dividerHeight="0dp"
        android:overScrollMode="never" />

</LinearLayout>
