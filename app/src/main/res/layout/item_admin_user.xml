<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardUser"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/stardeck_surface_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/stardeck_field_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Row 1: Avatar circle + Name/Email ─────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Avatar circle (solid primary color oval background) -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">

                <!-- Oval background drawn inline - no external drawable needed -->
                <TextView
                    android:id="@+id/tvAvatarInitials"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_circle_primary"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Name + email column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="User Name"
                    android:textColor="@color/stardeck_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="user@email.com"
                    android:textColor="@color/stardeck_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Row 2: Badge chips ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvBadgeRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_neutral"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="user"
                android:textColor="@color/stardeck_text_primary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvBadgeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_badge_success"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="active"
                android:textColor="@color/stardeck_success_text"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvBadgePremium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_badge_gold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="★ premium"
                android:textColor="@color/stardeck_gold_text"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ── Thin divider ──────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp"
            android:background="@color/stardeck_divider" />

        <!-- ── Row 3: Action buttons ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Edit"
                android:textColor="@color/stardeck_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:layout_marginHorizontal="2dp"
                android:background="@color/stardeck_divider" />

            <TextView
                android:id="@+id/btnResetPw"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Reset PW"
                android:textColor="@color/stardeck_text_secondary"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:layout_marginHorizontal="2dp"
                android:background="@color/stardeck_divider" />

            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Delete"
                android:textColor="@color/stardeck_error"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
