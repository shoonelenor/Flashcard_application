<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stardeck_bg_bottom">

    <!-- ── AppBar ── -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/stardeck_bg_bottom"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/stardeck_bg_bottom"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            app:navigationIconTint="@color/stardeck_text_primary"
            app:titleTextColor="@color/stardeck_text_primary"
            app:subtitleTextColor="@color/stardeck_text_secondary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Stats row: Known • Hard • Shuffle • Due -->
        <TextView
            android:id="@+id/tvStats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Known 0 • Hard 0 • Shuffle Off • Due"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/stardeck_text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Cards left counter -->
        <TextView
            android:id="@+id/tvCardsLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0 cards left"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/stardeck_text_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStats" />

        <!-- Divider below counter -->
        <View
            android:id="@+id/topDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/stardeck_field_stroke"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCardsLeft" />

        <!-- ── Flashcard ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/stardeck_field_bg"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/swipeHint"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topDivider"
            app:strokeColor="@color/stardeck_field_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- QUESTION label -->
                <TextView
                    android:id="@+id/labelQuestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.10"
                    android:text="QUESTION"
                    android:textAllCaps="true"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/stardeck_text_secondary" />

                <!-- Front text -->
                <TextView
                    android:id="@+id/tvFront"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Front"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textColor="@color/stardeck_text_primary" />

                <!-- Answer divider -->
                <View
                    android:id="@+id/divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="@color/stardeck_field_stroke"
                    android:visibility="gone" />

                <!-- ANSWER label -->
                <TextView
                    android:id="@+id/labelAnswer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:letterSpacing="0.10"
                    android:text="ANSWER"
                    android:textAllCaps="true"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/stardeck_primary"
                    android:visibility="gone" />

                <!-- Back / Answer text -->
                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Back"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="@color/stardeck_text_primary"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Swipe hint -->
        <TextView
            android:id="@+id/swipeHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="← Hard  •  → Known"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/stardeck_text_secondary"
            app:layout_constraintBottom_toTopOf="@id/bottomArea"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardContainer" />

        <!-- ── Bottom action area ── -->
        <LinearLayout
            android:id="@+id/bottomArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Show Answer / Hard+Known slot -->
            <FrameLayout
                android:id="@+id/actionSlot"
                android:layout_width="match_parent"
                android:layout_height="56dp">

                <!-- Show Answer button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShowAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Show Answer"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/stardeck_primary"
                    app:cornerRadius="28dp" />

                <!-- Hard / Known rating buttons -->
                <LinearLayout
                    android:id="@+id/groupRate"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="invisible">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHard"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Hard"
                        android:textAllCaps="false"
                        android:textColor="@color/stardeck_text_primary"
                        app:cornerRadius="28dp"
                        app:strokeColor="@color/stardeck_field_stroke" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnKnown"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Known"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/stardeck_primary"
                        app:cornerRadius="28dp" />
                </LinearLayout>

            </FrameLayout>

            <!-- Undo / Shuffle text buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUndo"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Undo"
                    android:textAllCaps="false"
                    android:textColor="@color/stardeck_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShuffle"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Shuffle"
                    android:textAllCaps="false"
                    android:textColor="@color/stardeck_primary" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>