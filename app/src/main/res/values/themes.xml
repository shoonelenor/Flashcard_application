<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Base theme: Material3 DayNight, no action bar.
        All colorPrimary / colorSurface etc. are wired to our StarDeck
        token set so Material3 components (buttons, inputs, dialogs)
        automatically pick up the correct colours.
    -->
    <style name="Base.Theme.StarDeckApplication"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- System bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <!-- M3 colour roles -->
        <item name="colorPrimary">@color/stardeck_primary</item>
        <item name="colorPrimaryVariant">@color/stardeck_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/stardeck_bottom_nav_icon_active</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/stardeck_surface_card</item>
        <item name="colorOnSurface">@color/stardeck_text_primary</item>

        <item name="android:colorBackground">@color/stardeck_surface</item>
        <item name="colorOnBackground">@color/stardeck_text_primary</item>

        <item name="colorError">@color/stardeck_error</item>
        <item name="colorOnError">@color/white</item>

        <!-- TextInputLayout focused stroke -->
        <item name="colorControlActivated">@color/stardeck_primary</item>

        <!-- Window background for activities without a custom bg drawable -->
        <item name="android:windowBackground">@color/stardeck_surface</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">@color/stardeck_ripple</item>

        <!-- Button corner radius (48dp = pill for 56dp-tall buttons) -->
        <item name="materialButtonStyle">@style/Widget.StarDeck.Button</item>

        <!-- TextInputLayout -->
        <item name="textInputStyle">@style/Widget.StarDeck.TextInputLayout</item>
    </style>

    <style name="Theme.StarDeckApplication"
        parent="Base.Theme.StarDeckApplication" />

    <!-- ── Component Styles ─────────────────────────────────────────── -->

    <!-- Primary filled pill button -->
    <style name="Widget.StarDeck.Button"
        parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">28dp</item>
        <item name="backgroundTint">@color/stardeck_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Text / ghost button -->
    <style name="Widget.StarDeck.Button.Text"
        parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/stardeck_link</item>
    </style>

    <!-- Outlined input (dark-space style) -->
    <style name="Widget.StarDeck.TextInputLayout"
        parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/stardeck_field_bg</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/stardeck_field_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintEnabled">false</item>
        <item name="android:textColorHint">@color/stardeck_text_hint</item>
    </style>

    <!-- Card surface -->
    <style name="Widget.StarDeck.Card"
        parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/stardeck_surface_card</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/stardeck_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>
