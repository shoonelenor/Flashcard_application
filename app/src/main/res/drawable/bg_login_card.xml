<?xml version="1.0" encoding="utf-8"?>
<!--
    Frosted-glass style card surface for the login form panel.
    Fill colour matches stardeck_surface_card with a subtle border
    matching stardeck_divider.  Corner radius 24dp.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#F018234A" />
    <stroke
        android:width="1dp"
        android:color="#FF1F2B4D" />
    <corners android:radius="24dp" />
</shape>
