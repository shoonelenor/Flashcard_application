<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base deep space -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="@color/stardeck_bg_top"
                android:endColor="@color/stardeck_bg_bottom"
                android:type="linear" />
        </shape>
    </item>

    <!-- Soft radial glow -->
    <item
        android:top="-140dp"
        android:left="-80dp"
        android:right="-80dp">
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="520dp"
                android:centerX="0.5"
                android:centerY="0.0"
                android:startColor="@color/stardeck_glow"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

</layer-list>