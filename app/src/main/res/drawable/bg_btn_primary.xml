<?xml version="1.0" encoding="utf-8"?>
<!--
    Pill-shaped primary button background with ripple feedback.
    Default fill = stardeck_primary (#4F6BFF)
    Pressed fill  = stardeck_primary_dark (#3A52E0)
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#334F6BFF">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF4F6BFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</ripple>
